---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- Hero -->
  <div class="py-12 sm:py-20 text-center">
    <p class="text-indigo-600 dark:text-indigo-400 font-medium text-sm tracking-wide uppercase mb-3">Explore the cosmos</p>
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-white">
      Galaxy Stack
    </h1>
    <p class="mt-4 text-lg text-gray-500 dark:text-space-400 max-w-xl mx-auto">
      Log celestial discoveries. Static HTML + SpacetimeDB. No servers to manage, no WebSockets to pay for.
    </p>
    <div class="mt-8 flex items-center justify-center gap-4">
      <a href="/discoveries" class="px-6 py-2.5 bg-indigo-600 text-white rounded-lg text-sm font-medium hover:bg-indigo-500 transition-colors shadow-lg shadow-indigo-500/20">
        View Discoveries
      </a>
      <a href="/login" class="px-6 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm
        bg-white text-gray-700 border border-gray-300 hover:bg-gray-50
        dark:bg-space-800 dark:text-space-200 dark:border-space-600 dark:hover:bg-space-700">
        Sign In
      </a>
    </div>
  </div>

  <!-- Feature cards -->
  <div class="grid sm:grid-cols-3 gap-6 mt-8">
    <div class="rounded-xl p-6 shadow-sm transition-colors
      bg-white border border-gray-200
      dark:bg-space-800/50 dark:border-space-700/50 dark:shadow-none">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-xl
        bg-indigo-50 dark:bg-indigo-500/10">
        &#9889;
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-space-100">Static & Fast</h3>
      <p class="mt-2 text-sm text-gray-500 dark:text-space-400">Pre-built HTML served from Cloudflare's CDN. No server rendering, no cold starts.</p>
    </div>

    <div class="rounded-xl p-6 shadow-sm transition-colors
      bg-white border border-gray-200
      dark:bg-space-800/50 dark:border-space-700/50 dark:shadow-none">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-xl
        bg-green-50 dark:bg-green-500/10">
        &#128274;
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-space-100">Built-in Auth</h3>
      <p class="mt-2 text-sm text-gray-500 dark:text-space-400">SpacetimeDB identity tokens with OAuth linking. Google, GitHub — just add a button.</p>
    </div>

    <div class="rounded-xl p-6 shadow-sm transition-colors
      bg-white border border-gray-200
      dark:bg-space-800/50 dark:border-space-700/50 dark:shadow-none">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center mb-4 text-xl
        bg-purple-50 dark:bg-purple-500/10">
        &#128640;
      </div>
      <h3 class="font-semibold text-gray-900 dark:text-space-100">One Backend</h3>
      <p class="mt-2 text-sm text-gray-500 dark:text-space-400">SpacetimeDB is your database and server. Business logic in Rust WASM. ~&euro;5/mo.</p>
    </div>
  </div>
</Layout>
