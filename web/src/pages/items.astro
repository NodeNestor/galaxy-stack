---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Items">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900">Items</h1>
      <p class="text-sm text-gray-500 mt-1" id="item-count">Loading...</p>
    </div>
    <button id="create-btn"
      class="px-4 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors shadow-sm">
      + New Item
    </button>
  </div>

  <!-- Create form (hidden by default) -->
  <div id="create-panel" class="hidden mb-8">
    <form id="create-form" class="bg-white rounded-xl border border-gray-200 p-6 shadow-sm space-y-4">
      <div class="flex items-center justify-between mb-2">
        <h2 class="text-lg font-semibold text-gray-900">New Item</h2>
        <button type="button" id="cancel-btn" class="text-sm text-gray-400 hover:text-gray-600 transition-colors">Cancel</button>
      </div>
      <div>
        <label for="title" class="block text-sm font-medium text-gray-700 mb-1">Title</label>
        <input type="text" id="title" name="title" maxlength="200" required
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-shadow"
          placeholder="What are you adding?" />
      </div>
      <div>
        <label for="description" class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea id="description" name="description" rows="3" maxlength="10000"
          class="w-full border border-gray-300 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-blue-500 focus:border-blue-500 outline-none transition-shadow"
          placeholder="Add some details..."></textarea>
      </div>
      <div class="flex justify-end gap-3">
        <button type="button" id="cancel-btn-2" class="px-4 py-2 text-sm text-gray-600 hover:text-gray-900 transition-colors">Cancel</button>
        <button type="submit" id="submit-btn"
          class="px-5 py-2 bg-blue-600 text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition-colors shadow-sm">
          Create Item
        </button>
      </div>
    </form>
  </div>

  <!-- Items grid -->
  <div id="items" class="grid gap-4">
    <div id="empty-state" class="text-center py-16">
      <div class="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
        </svg>
      </div>
      <p class="text-gray-400 text-sm">No items yet</p>
      <p class="text-gray-300 text-xs mt-1">Create one to get started</p>
    </div>
  </div>

  <!-- Toast -->
  <div id="toast" class="fixed bottom-6 right-6 hidden">
    <div class="bg-gray-900 text-white text-sm px-4 py-2.5 rounded-lg shadow-lg flex items-center gap-2">
      <svg class="w-4 h-4 text-green-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
      </svg>
      <span id="toast-msg">Done</span>
    </div>
  </div>
</Layout>

<script>
  import { query, call, esc } from '../lib/api';
  import { getStoredIdentity } from '../lib/auth';

  const itemsEl = document.getElementById('items')!;
  const itemCountEl = document.getElementById('item-count')!;
  const emptyState = document.getElementById('empty-state')!;
  const createForm = document.getElementById('create-form') as HTMLFormElement;
  const createPanel = document.getElementById('create-panel')!;
  const createBtn = document.getElementById('create-btn')!;
  const submitBtn = document.getElementById('submit-btn')!;
  const toast = document.getElementById('toast')!;
  const toastMsg = document.getElementById('toast-msg')!;

  // Toggle create form
  createBtn.addEventListener('click', () => {
    createPanel.classList.toggle('hidden');
    if (!createPanel.classList.contains('hidden')) {
      (document.getElementById('title') as HTMLInputElement).focus();
    }
  });
  document.getElementById('cancel-btn')!.addEventListener('click', () => createPanel.classList.add('hidden'));
  document.getElementById('cancel-btn-2')!.addEventListener('click', () => createPanel.classList.add('hidden'));

  // Show toast
  function showToast(msg: string) {
    toastMsg.textContent = msg;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 2500);
  }

  // Fetch and render
  let currentIdentity: string | null = null;

  async function fetchItems() {
    try {
      const rows = await query('SELECT * FROM item');
      currentIdentity = getStoredIdentity();
      renderItems(rows);
    } catch {
      itemCountEl.textContent = 'Could not load items';
    }
  }

  function renderItems(rows: any[]) {
    itemCountEl.textContent = `${rows.length} item${rows.length !== 1 ? 's' : ''}`;
    itemsEl.querySelectorAll('.item-card').forEach(el => el.remove());

    if (rows.length === 0) {
      emptyState.style.display = '';
      return;
    }
    emptyState.style.display = 'none';

    for (const [id, owner, title, description] of rows) {
      const isOwner = currentIdentity && owner === currentIdentity;
      const card = document.createElement('div');
      card.className = 'item-card bg-white rounded-xl border border-gray-200 p-5 shadow-sm hover:shadow-md transition-shadow';
      card.innerHTML = `
        <div class="flex justify-between items-start gap-4">
          <div class="min-w-0">
            <h3 class="font-semibold text-gray-900 truncate">${esc(title)}</h3>
            <p class="text-gray-500 text-sm mt-1 line-clamp-2">${esc(description || '')}</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="text-xs text-gray-300 font-mono">#${id}</span>
            ${isOwner ? `<button data-delete="${id}" class="text-xs text-red-400 hover:text-red-600 transition-colors p-1">Delete</button>` : ''}
          </div>
        </div>
      `;
      itemsEl.appendChild(card);
    }

    // Delete handlers
    itemsEl.querySelectorAll('[data-delete]').forEach(btn => {
      btn.addEventListener('click', async () => {
        const id = parseInt((btn as HTMLElement).dataset.delete!, 10);
        const ok = await call('delete_item', [id]);
        if (ok) {
          showToast('Item deleted');
          setTimeout(fetchItems, 300);
        } else {
          showToast('Could not delete item');
        }
      });
    });
  }

  // Form submit
  createForm.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Creating...';
    submitBtn.setAttribute('disabled', '');

    const title = (document.getElementById('title') as HTMLInputElement).value;
    const desc = (document.getElementById('description') as HTMLTextAreaElement).value;

    const ok = await call('create_item', [title, desc]);

    submitBtn.textContent = 'Create Item';
    submitBtn.removeAttribute('disabled');

    if (ok) {
      createForm.reset();
      createPanel.classList.add('hidden');
      showToast('Item created');
      setTimeout(fetchItems, 300);
    } else {
      showToast('Could not create item');
    }
  });

  fetchItems();
</script>
